{
  "version": 1,
  "author": "Julian",
  "editor": "wokwi",
  "parts": [
    {
      "type": "wokwi-pi-pico",
      "id": "pico",
      "top": 0,
      "left": 0,
      "rotate": 0,
      "attrs": { "env": "circuitpython-9" }
    },
    {
      "type": "wokwi-photoresistor-sensor",
      "id": "ldr1",
      "top": -100,
      "left": -180,
      "rotate": 0,
      "attrs": {}
    },
    {
      "type": "wokwi-resistor",
      "id": "r_pulldown",
      "top": 10,
      "left": -180,
      "rotate": 90,
      "attrs": { "value": "10000" }
    },
    {
      "type": "wokwi-led",
      "id": "led1",
      "top": -50,
      "left": 310,
      "rotate": 0,
      "attrs": { "color": "white" }
    },
    {
      "type": "wokwi-resistor",
      "id": "r_led",
      "top": -30,
      "left": 230,
      "rotate": 0,
      "attrs": { "value": "220" }
    },
    {
      "type": "wokwi-text",
      "id": "label_sensor",
      "top": -130,
      "left": -200,
      "attrs": { "text": "Sensorfunktion:\nHelligkeitsmessung" }
    },
    {
      "type": "wokwi-text",
      "id": "label_aktor",
      "top": -80,
      "left": 230,
      "attrs": { "text": "Aktorfunktion:\nLichtstellen" }
    }
  ],
  "connections": [
    ["ldr1:VCC", "pico:3V3", "red", ["v20", "h80"]],
    ["ldr1:GND", "pico:GND.1", "black", ["v30", "h90"]],
    ["ldr1:AO", "pico:GP26", "purple", ["v50", "h60"]],
    ["ldr1:AO", "r_pulldown:1", "purple", ["v0"]],
    ["r_pulldown:2", "pico:GND.1", "black", ["v10", "h60"]],
    ["pico:GP15", "r_led:1", "green", ["h10"]],
    ["r_led:2", "led1:A", "green", ["h0"]],
    ["led1:C", "pico:GND.8", "black", ["v20", "h-40"]]
  ]
}
